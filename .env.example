# =============================================================================
# ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# Este arquivo é um EXEMPLO de quais variáveis de ambiente você precisa.
# Nunca commit arquivos .env reais com valores sensíveis!
#
# Para usar:
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Preencha os valores reais em .env.local
# 3. O .env.local nunca será commitado (está no .gitignore)
# =============================================================================

# =============================================================================
# ANALYTICS (Vite)
# =============================================================================
# URL do endpoint de analytics
VITE_ANALYTICS_ENDPOINT=https://manus-analytics.com

# ID do website para tracking
VITE_ANALYTICS_WEBSITE_ID=seu-website-id-aqui

# =============================================================================
# APP CONFIG
# =============================================================================
# ID da aplicação (fornecido pelo Manus)
VITE_APP_ID=seu-app-id-aqui

# Título da aplicação
VITE_APP_TITLE=NovaCore's - Software House

# Logo da aplicação (URL)
VITE_APP_LOGO=https://seu-dominio.com/logo.png

# =============================================================================
# FORGE API (Manus Backend)
# =============================================================================
# Frontend Forge API URL
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai

# Frontend Forge API Key (publicável, para o frontend)
VITE_FRONTEND_FORGE_API_KEY=sua-chave-publica-aqui

# =============================================================================
# BACKEND ONLY (Nunca exponha no frontend!)
# =============================================================================
# Backend Forge API Key (SENSÍVEL - só no servidor)
# BUILT_IN_FORGE_API_KEY=sua-chave-privada-aqui

# Backend Forge API URL
# BUILT_IN_FORGE_API_URL=https://forge.manus.ai

# =============================================================================
# OAUTH & AUTENTICAÇÃO
# =============================================================================
# URL do servidor OAuth
# OAUTH_SERVER_URL=https://api.manus.im

# JWT Secret para assinar tokens (SENSÍVEL)
# JWT_SECRET=seu-jwt-secret-aleatorio-super-secreto

# =============================================================================
# DATABASE (Se adicionar no futuro)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/novacore_db
# DATABASE_USER=seu-usuario
# DATABASE_PASSWORD=sua-senha

# =============================================================================
# EMAIL SERVICE (Se adicionar no futuro)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-de-app

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
# development, production, test
NODE_ENV=development

# =============================================================================
# SERVER
# =============================================================================
# Porta do servidor
PORT=3000

# Hostname
HOST=localhost
